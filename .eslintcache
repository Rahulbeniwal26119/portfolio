\"ten columns\">\n                    <p className=\"lead\">{data?.message}</p>\n                </div>\n            </div>\n            <div className=\"row\">\n                <div className=\"eight columns\">\n                    <form id=\"contactForm\" name=\"contactForm\">\n                        <fieldset>\n                            <div>\n                                <label htmlFor=\"contactName\">Name <span className=\"required\">*</span></label>\n                                <input value={name} type=\"text\" defaultValue=\"\" size=\"35\" id=\"contactName\" name=\"contactName\" onChange={(e => setName(e.target.value))}/>\n                            </div>\n                            <div>\n\t\t\t\t\t\t   <label htmlFor=\"contactEmail\">Email <span className=\"required\">*</span></label>\n\t\t\t\t\t\t   <input value={email} type=\"text\" defaultValue=\"\" size=\"35\" id=\"contactEmail\" name=\"contactEmail\" onChange={e=> setEmail(e.target.value)}/>\n                  </div>\n\n                  <div>\n\t\t\t\t\t\t   <label htmlFor=\"contactSubject\">Subject</label>\n\t\t\t\t\t\t   <input value={subject} type=\"text\" defaultValue=\"\" size=\"35\" id=\"contactSubject\" name=\"contactSubject\" onChange={e => setSubject(e.target.value)}/>\n                  </div>\n\n                  <div>\n                     <label htmlFor=\"contactMessage\">Message <span className=\"required\">*</span></label>\n                     <textarea value={message} onChange={e => setMessage(e.target.value)} cols=\"50\" rows=\"15\" id=\"contactMessage\" name=\"contactMessage\"></textarea>\n                  </div>\n                  <div>\n                      <button type=\"submit\" onClick={handleClick} className=\"submit\">Submit</button>\n                      <span id=\"image-loader\">\n                          <img alt=\"\" src={require(\"./portfolio/loader.gif\")}/>\n                      </span>\n                  </div>\n                        </fieldset>\n                    </form>\n                    <div id=\"message-warning\"> Error in sending message</div>\n                    <div id=\"message-success\">\n                        <i className=\"fa fa-check\"></i>Your message was sent, thank you! <br />\n                    </div>\n                </div>\n                <aside className=\"four columns footer-widget\">\n                        <div className=\"widget widget_contact\">\n                            <h4>Address and Phone</h4>\n                            <p className=\"address\">\n                                {data?.name}<br/>\n                                {data?.address.city }, {data?.address.state} , {data?.address.pin}<br/>\n                                {data?.phone}<br/>\n                            </p>\n                        </div>\n                        <div className=\"widget widget_tweeks\">\n                        </div>\n                </aside>\n            </div>\n        </section>\n    )   \n}\nexport default Contact;","/home/rahul/react/portfolio/src/Component/Footer.js",[],{"ruleId":"48","replacedBy":"49"},{"ruleId":"50","replacedBy":"51"},{"ruleId":"52","severity":1,"message":"53","line":4,"column":12,"nodeType":"54","messageId":"55","endLine":4,"endColumn":15},{"ruleId":"52","severity":1,"message":"56","line":4,"column":18,"nodeType":"54","messageId":"55","endLine":4,"endColumn":24},"no-native-reassign",["57"],"no-negated-in-lhs",["58"],"no-unused-vars","'url' is assigned a value but never used.","Identifier","unusedVar","'setUrl' is assigned a value but never used.","no-global-assign","no-unsafe-negation"]